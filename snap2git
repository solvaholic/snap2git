#!/usr/bin/env bash
#
# snap2git - Use Git as invisible snapshot plumbing for file collections.
#
# The cloud drive folder IS the work tree. A bare Git repo elsewhere
# stores the history. No .git folder pollutes your cloud drive.
#
set -euo pipefail

SNAP2GIT_VERSION="0.5.0"
SNAP2GIT_HOME="${SNAP2GIT_HOME:-$HOME/.snap2git}"
SNAP2GIT_CONFIG="${SNAP2GIT_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/snap2git/config}"
LARGE_FILE_WARN_BYTES=$((50 * 1024 * 1024))  # 50 MB
SNAP2GIT_TMPFILES=()

# --- Cleanup and signal handling -------------------------------------------

cleanup() {
  local exit_status=$?
  for f in "${SNAP2GIT_TMPFILES[@]:-}"; do
    [[ -f "$f" ]] && rm -f "$f" 2>/dev/null
  done
  exit "$exit_status"
}
trap cleanup EXIT INT TERM

# --- Helpers ---------------------------------------------------------------

die() { echo "error: $*" >&2; exit 1; }
warn() { echo "warning: $*" >&2; }
info() { echo "$*"; }

# Run git with the right --git-dir and --work-tree for a named repo.
snap_git() {
  local name="$1"; shift
  local gitdir worktree
  gitdir="$(repo_gitdir "$name")"
  worktree="$(repo_worktree "$name")"
  git --git-dir="$gitdir" --work-tree="$worktree" "$@"
}

# Expand ~ in paths (config values aren't shell-expanded by default).
expand_path() {
  local p="$1"
  # shellcheck disable=SC2088 # Intentional: matching literal ~/ prefix, not expanding
  if [[ "$p" == "~/"* ]]; then
    p="$HOME/${p#\~/}"
  fi
  echo "$p"
}

# --- Config ----------------------------------------------------------------

# Read a key from a [repo:<name>] section in the config file.
config_get() {
  local name="$1" key="$2" default="${3:-}"
  if [[ ! -f "$SNAP2GIT_CONFIG" ]]; then
    echo "$default"
    return
  fi
  local value
  value=$(awk -v section="repo:$name" -v key="$key" '
    BEGIN { in_section = 0 }
    /^[#;]/ { next }
    /^[[:space:]]*$/ { next }
    /^\[/ {
      gsub(/[][]/, "", $0)
      in_section = ($0 == section) ? 1 : 0
      next
    }
    in_section && $0 ~ "^" key " *= *" {
      sub(/^[^=]*= */, "")
      print
      exit
    }
  ' "$SNAP2GIT_CONFIG")
  echo "${value:-$default}"
}

# Write or update a key in a [repo:<name>] section.
config_set() {
  local name="$1" key="$2" value="$3"
  local config_dir
  config_dir="$(dirname "$SNAP2GIT_CONFIG")"
  mkdir -p "$config_dir"

  if [[ ! -f "$SNAP2GIT_CONFIG" ]]; then
    printf '[repo:%s]\n%s = %s\n' "$name" "$key" "$value" > "$SNAP2GIT_CONFIG"
    return
  fi

  # Check if section exists
  if grep -q "^\[repo:${name}\]" "$SNAP2GIT_CONFIG"; then
    # Check if key exists in section
    local tmp
    tmp=$(mktemp)
    SNAP2GIT_TMPFILES+=("$tmp")
    awk -v section="repo:$name" -v key="$key" -v val="$value" '
      BEGIN { in_section = 0; found = 0 }
      /^\[/ {
        if (in_section && !found) {
          printf "%s = %s\n", key, val
          found = 1
        }
        header = $0
        gsub(/[][]/, "", header)
        in_section = (header == section) ? 1 : 0
        print; next
      }
      in_section && $0 ~ "^" key " *= *" {
        printf "%s = %s\n", key, val
        found = 1; next
      }
      { print }
      END { if (in_section && !found) printf "%s = %s\n", key, val }
    ' "$SNAP2GIT_CONFIG" > "$tmp"
    mv "$tmp" "$SNAP2GIT_CONFIG"
  else
    # Append new section
    printf '\n[repo:%s]\n%s = %s\n' "$name" "$key" "$value" >> "$SNAP2GIT_CONFIG"
  fi
}

# List all configured repo names.
config_list_repos() {
  if [[ ! -f "$SNAP2GIT_CONFIG" ]]; then
    return
  fi
  grep '^\[repo:' "$SNAP2GIT_CONFIG" | sed 's/\[repo:\(.*\)\]/\1/'
}

# List all configured group names.
config_list_groups() {
  if [[ ! -f "$SNAP2GIT_CONFIG" ]]; then
    return
  fi
  grep '^\[group:' "$SNAP2GIT_CONFIG" | sed 's/\[group:\(.*\)\]/\1/'
}

# Get the repos in a group (comma-separated in config, returned one per line).
config_get_group_repos() {
  local group="$1"
  if [[ ! -f "$SNAP2GIT_CONFIG" ]]; then
    return
  fi
  local raw
  raw=$(awk -v section="group:$group" -v key="repos" '
    BEGIN { in_section = 0 }
    /^[#;]/ { next }
    /^[[:space:]]*$/ { next }
    /^\[/ {
      gsub(/[][]/, "", $0)
      in_section = ($0 == section) ? 1 : 0
      next
    }
    in_section && $0 ~ "^" key " *= *" {
      sub(/^[^=]*= */, "")
      print
      exit
    }
  ' "$SNAP2GIT_CONFIG")
  # Split comma-separated list, trim whitespace
  echo "$raw" | tr ',' '\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' | grep -v '^$' || true
}

# Set the repos list for a group in config.
config_set_group() {
  local group="$1" repos_csv="$2"
  local config_dir
  config_dir="$(dirname "$SNAP2GIT_CONFIG")"
  mkdir -p "$config_dir"

  if [[ ! -f "$SNAP2GIT_CONFIG" ]]; then
    printf '[group:%s]\nrepos = %s\n' "$group" "$repos_csv" > "$SNAP2GIT_CONFIG"
    return
  fi

  if grep -q "^\[group:${group}\]" "$SNAP2GIT_CONFIG"; then
    local tmp
    tmp=$(mktemp)
    SNAP2GIT_TMPFILES+=("$tmp")
    awk -v section="group:$group" -v key="repos" -v val="$repos_csv" '
      BEGIN { in_section = 0; found = 0 }
      /^\[/ {
        if (in_section && !found) {
          printf "%s = %s\n", key, val
          found = 1
        }
        header = $0
        gsub(/[][]/, "", header)
        in_section = (header == section) ? 1 : 0
        print; next
      }
      in_section && $0 ~ "^" key " *= *" {
        printf "%s = %s\n", key, val
        found = 1; next
      }
      { print }
      END { if (in_section && !found) printf "%s = %s\n", key, val }
    ' "$SNAP2GIT_CONFIG" > "$tmp"
    mv "$tmp" "$SNAP2GIT_CONFIG"
  else
    printf '\n[group:%s]\nrepos = %s\n' "$group" "$repos_csv" >> "$SNAP2GIT_CONFIG"
  fi
}

# Remove a group section from config.
config_remove_group() {
  local group="$1"
  if [[ ! -f "$SNAP2GIT_CONFIG" ]]; then
    return
  fi
  local tmp
  tmp=$(mktemp)
  SNAP2GIT_TMPFILES+=("$tmp")
  awk -v section="group:$group" '
    BEGIN { in_section = 0 }
    /^\[/ {
      header = $0
      gsub(/[][]/, "", header)
      in_section = (header == section) ? 1 : 0
      if (!in_section) print
      next
    }
    !in_section { print }
  ' "$SNAP2GIT_CONFIG" > "$tmp"
  mv "$tmp" "$SNAP2GIT_CONFIG"
}

# Check if a name is a group.
is_group() {
  local name="$1"
  local groups
  groups="$(config_list_groups)"
  if [[ -n "$groups" ]]; then
    echo "$groups" | grep -qx "$name"
    return $?
  fi
  return 1
}

# Validate config file structure. Returns errors on stderr.
# With --force, warnings are printed but execution continues.
config_validate() {
  if [[ ! -f "$SNAP2GIT_CONFIG" ]]; then
    return 0
  fi

  local errors=0
  local line_num=0
  local current_section=""

  while IFS= read -r line; do
    line_num=$((line_num + 1))

    # Skip comments and blank lines
    [[ "$line" =~ ^[#\;] ]] && continue
    [[ -z "${line// /}" ]] && continue

    # Section header
    if [[ "$line" =~ ^\[.*\]$ ]]; then
      current_section="${line//[\[\]]/}"
      if [[ ! "$current_section" =~ ^(repo|group): ]]; then
        warn "config line $line_num: unknown section type '[$current_section]' (expected [repo:NAME] or [group:NAME])"
        errors=$((errors + 1))
      fi
      continue
    fi

    # Key = value
    if [[ "$line" =~ ^[a-z_]+[[:space:]]*= ]]; then
      continue
    fi

    warn "config line $line_num: unrecognized line: $line"
    errors=$((errors + 1))
  done < "$SNAP2GIT_CONFIG"

  # Check each repo section has a worktree key
  local repos
  repos="$(config_list_repos)"
  if [[ -n "$repos" ]]; then
    while IFS= read -r name; do
      local wt
      wt="$(config_get "$name" "worktree" "")"
      if [[ -z "$wt" ]]; then
        warn "config: repo '$name' is missing required 'worktree' key"
        errors=$((errors + 1))
      fi
    done <<< "$repos"
  fi

  return "$errors"
}

# Show config for a repo, or set a key.
config_show() {
  local name="$1"
  if [[ ! -f "$SNAP2GIT_CONFIG" ]]; then
    die "no config file found at $SNAP2GIT_CONFIG"
  fi
  awk -v section="repo:$name" '
    BEGIN { in_section = 0 }
    /^\[/ {
      header = $0
      gsub(/[][]/, "", header)
      in_section = (header == section) ? 1 : 0
      if (in_section) print $0
      next
    }
    in_section { print }
  ' "$SNAP2GIT_CONFIG"
}

repo_gitdir() {
  local name="$1"
  echo "$SNAP2GIT_HOME/${name}.git"
}

repo_worktree() {
  local name="$1"
  local wt
  wt="$(config_get "$name" "worktree" "")"
  [[ -z "$wt" ]] && die "no worktree configured for repo '$name'"
  expand_path "$wt"
}

# Validate that a repo's git-dir and worktree are present and usable.
require_repo() {
  local name="$1"
  local gitdir worktree
  gitdir="$(repo_gitdir "$name")"
  worktree="$(repo_worktree "$name")"
  if [[ ! -d "$gitdir" ]]; then
    die "repo '$name' not initialized (run snap2git init first)"
  fi
  if ! git --git-dir="$gitdir" rev-parse --git-dir >/dev/null 2>&1; then
    die "git-dir for '$name' is not a valid Git repository: $gitdir"
  fi
  if [[ ! -d "$worktree" ]]; then
    die "worktree for '$name' not found: $worktree (has the folder moved?)"
  fi

  # Backfill git identity for repos created before v0.2
  if ! git --git-dir="$gitdir" config user.name >/dev/null 2>&1; then
    git --git-dir="$gitdir" config user.name "snap2git"
    git --git-dir="$gitdir" config user.email "snap2git@localhost"
  fi
}

# --- Default exclude rules -------------------------------------------------

write_default_excludes() {
  local gitdir="$1"
  local exclude_file="$gitdir/info/exclude"
  mkdir -p "$gitdir/info"
  cat > "$exclude_file" << 'EXCLUDES'
# snap2git default excludes
# Edit with: snap2git exclude <name> --edit

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Cloud provider sync markers and placeholders
.dropbox
.dropbox.attr
.dropbox.cache/
.icloud
*.icloud
.fuse_hidden*
.OneDrive*
*.tmp.drivedownload
*.tmp.driveupload

# Temp and lock files
*~
*.swp
*.swo
*.tmp
*.bak
~$*.doc*
~$*.xls*
~$*.ppt*
*.lock

# IDE and editor state
.idea/
.vscode/*.log
*.pyc
__pycache__/
.*.sw?

# Common large binary formats (optional - comment out if needed)
# *.iso
# *.dmg
# *.vmdk
EXCLUDES
  info "Wrote default exclude rules to $exclude_file"
}

# --- Exclude presets -------------------------------------------------------

preset_calibre() {
  cat << 'PRESET'

# -- preset: calibre --
# Calibre app state (not library content)
.cache/
.config/
.calnotes/
full-text-search.db
metadata_db_prefs_backup.json
PRESET
}

preset_obsidian() {
  cat << 'PRESET'

# -- preset: obsidian --
# Obsidian vault metadata (not your notes)
.obsidian/
PRESET
}

# Add new presets as functions: preset_<name>()

# Map preset names to detection signatures (files/dirs in worktree root).
preset_detect_signatures() {
  # Format: preset_name:signature (checked with -e at worktree root)
  echo "calibre:metadata.db"
  echo "calibre:.caltrash"
  echo "obsidian:.obsidian"
}

# Detect which presets match a worktree (root-only scan).
# Prints matching preset names, one per line, deduplicated.
detect_presets() {
  local worktree="$1"
  local seen="" line preset sig
  while IFS= read -r line; do
    preset="${line%%:*}"
    sig="${line#*:}"
    if [[ -e "$worktree/$sig" ]]; then
      # Deduplicate: only print each preset once
      if [[ ":$seen:" != *":$preset:"* ]]; then
        echo "$preset"
        seen="$seen:$preset"
      fi
    fi
  done < <(preset_detect_signatures)
}

preset_list() {
  echo "Available presets:"
  echo "  calibre   - Excludes Calibre app state (.cache, .config, .calnotes, etc.)"
  echo "  obsidian  - Excludes Obsidian vault metadata (.obsidian/)"
}

# --- Binary attributes (for gc) --------------------------------------------

write_binary_attributes() {
  local gitdir="$1"
  local attrs_file="$gitdir/info/attributes"
  mkdir -p "$gitdir/info"
  cat > "$attrs_file" << 'ATTRS'
# snap2git binary attributes - skip futile delta compression
# Regenerated by snap2git gc; manual edits will be overwritten.
*.epub -delta
*.pdf -delta
*.zip -delta
*.cbz -delta
*.cbr -delta
*.jpg -delta
*.jpeg -delta
*.png -delta
*.gif -delta
*.mp3 -delta
*.mp4 -delta
*.m4a -delta
*.m4v -delta
*.flac -delta
*.rar -delta
*.7z -delta
*.gz -delta
*.tar.gz -delta
ATTRS
}

# --- Garbage collection helpers --------------------------------------------

_gc_one() {
  local name="$1"
  require_repo "$name"
  local gitdir
  gitdir="$(repo_gitdir "$name")"

  write_binary_attributes "$gitdir"
  info "Running gc on '$name'..."
  git --git-dir="$gitdir" gc --aggressive --quiet
  info "GC complete for '$name'."
}

_maybe_auto_gc() {
  local name="$1"
  local gitdir
  gitdir="$(repo_gitdir "$name")"
  local count_file="$gitdir/snap2git-snapshot-count"
  local interval
  interval="$(config_get "$name" "auto_gc_interval" "50")"

  if [[ "$interval" == "0" ]]; then
    return 0
  fi

  local count=0
  if [[ -f "$count_file" ]]; then
    count=$(cat "$count_file")
  fi
  count=$((count + 1))

  if [[ "$count" -ge "$interval" ]]; then
    info "Auto-gc triggered after $count snapshots."
    write_binary_attributes "$gitdir"
    # Use plain gc (not --aggressive) for auto-gc to avoid latency spikes
    if git --git-dir="$gitdir" gc --quiet 2>/dev/null; then
      info "Auto-gc complete for '$name'."
    else
      warn "Auto-gc failed for '$name' (will retry after next snapshot)."
    fi
    count=0
  fi

  echo "$count" > "$count_file"
}

# --- Exclude subcommand ----------------------------------------------------

exclude_file_for() {
  local name="$1"
  local gitdir
  gitdir="$(repo_gitdir "$name")"
  echo "$gitdir/info/exclude"
}

cmd_exclude() {
  local name="" pattern="" action="add"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --list|-l)   action="list"; shift ;;
      --edit|-e)   action="edit"; shift ;;
      --reset)     action="reset"; shift ;;
      --preset|-p) action="preset"; shift; local preset_name="${1:-}"; [[ -n "${1:-}" ]] && shift ;;
      --help|-h) cmd_help; return 0 ;;
      -*) die "unknown option: $1" ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        else
          pattern="$1"
        fi
        shift
        ;;
    esac
  done

  [[ -z "$name" ]] && die "usage: snap2git exclude <name> [<pattern>] [--list|--edit|--reset|--preset <type>]"
  require_repo "$name"

  local exclude_file
  exclude_file="$(exclude_file_for "$name")"

  case "$action" in
    list)
      if [[ -f "$exclude_file" ]]; then
        cat "$exclude_file"
      else
        info "No exclude rules for '$name'."
      fi
      ;;
    edit)
      [[ -z "${EDITOR:-}" ]] && die "EDITOR is not set"
      info "Editing $exclude_file"
      "$EDITOR" "$exclude_file"
      ;;
    reset)
      local gitdir
      gitdir="$(repo_gitdir "$name")"
      write_default_excludes "$gitdir"
      info "Reset excludes to defaults for '$name'."
      ;;
    preset)
      [[ -z "${preset_name:-}" ]] && { preset_list; return 0; }
      local preset_func="preset_${preset_name}"
      if ! declare -f "$preset_func" >/dev/null 2>&1; then
        die "unknown preset: '$preset_name'"
      fi
      "$preset_func" >> "$exclude_file"
      info "Applied preset '$preset_name' to '$name'."
      ;;
    add)
      [[ -z "$pattern" ]] && die "usage: snap2git exclude <name> <pattern>"
      echo "$pattern" >> "$exclude_file"
      info "Added exclude pattern '$pattern' to '$name'."
      ;;
  esac
}

# --- Commands --------------------------------------------------------------

# Run a command function for each configured repo.
# Continues on failure, prints summary at end.
run_for_all() {
  local cmd_func="$1"; shift
  local repos failures=0 total=0

  repos="$(config_list_repos)"
  if [[ -z "$repos" ]]; then
    die "no repos configured (run 'snap2git init' first)"
  fi

  while IFS= read -r name; do
    total=$((total + 1))
    info "--- $name ---"
    # Run in subshell so die() doesn't kill the whole script
    if ! ( "$cmd_func" "$name" "$@" ); then
      warn "failed: $name"
      failures=$((failures + 1))
    fi
    echo
  done <<< "$repos"

  if [[ "$failures" -gt 0 ]]; then
    warn "$failures of $total repo(s) had errors."
    return 1
  fi
  info "All $total repo(s) completed successfully."
}

# Run a command function for each repo in a group.
run_for_group() {
  local group="$1" cmd_func="$2"; shift 2
  local repos failures=0 total=0

  repos="$(config_get_group_repos "$group")"
  if [[ -z "$repos" ]]; then
    die "group '$group' has no repos"
  fi

  while IFS= read -r name; do
    total=$((total + 1))
    info "--- $name ---"
    if ! ( "$cmd_func" "$name" "$@" ); then
      warn "failed: $name"
      failures=$((failures + 1))
    fi
    echo
  done <<< "$repos"

  if [[ "$failures" -gt 0 ]]; then
    warn "$failures of $total repo(s) in group '$group' had errors."
    return 1
  fi
  info "All $total repo(s) in group '$group' completed successfully."
}

cmd_init() {
  local name="" worktree_arg=""
  local no_excludes=false
  local explicit_presets=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --no-excludes) no_excludes=true; shift ;;
      --exclude-preset)
        [[ -z "${2:-}" ]] && die "--exclude-preset requires a preset name"
        explicit_presets+=("$2"); shift 2 ;;
      --help|-h) cmd_help; return 0 ;;
      -*)  die "unknown option: $1" ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        elif [[ -z "$worktree_arg" ]]; then
          worktree_arg="$1"
        else
          die "unexpected argument: $1"
        fi
        shift
        ;;
    esac
  done

  [[ -z "$name" ]] && die "usage: snap2git init <name> <worktree-path>"
  [[ -z "$worktree_arg" ]] && die "usage: snap2git init <name> <worktree-path>"

  local worktree gitdir
  worktree="$(expand_path "$worktree_arg")"

  [[ ! -d "$worktree" ]] && die "worktree path does not exist: $worktree"

  # Resolve to absolute path so config works from any working directory
  worktree="$(cd "$worktree" && pwd -P)"
  gitdir="$(repo_gitdir "$name")"
  [[ -d "$gitdir" ]] && die "git dir already exists: $gitdir (use a different name)"

  info "Initializing snap2git repo '$name'"
  info "  worktree: $worktree"
  info "  git-dir:  $gitdir"

  # Create bare repo
  mkdir -p "$gitdir"
  git init --bare "$gitdir" --quiet

  # Configure for cloud drive use
  git --git-dir="$gitdir" config core.fileMode false
  git --git-dir="$gitdir" config core.autocrlf input
  git --git-dir="$gitdir" config core.precomposeunicode true

  # Set a local identity so commits work in CI and fresh environments
  git --git-dir="$gitdir" config user.name "snap2git"
  git --git-dir="$gitdir" config user.email "snap2git@localhost"

  # Write exclude rules
  write_default_excludes "$gitdir"

  # Write binary attributes for efficient gc
  write_binary_attributes "$gitdir"

  # Apply exclude presets
  local exclude_file
  exclude_file="$(exclude_file_for "$name")"

  if ! $no_excludes; then
    # Apply explicitly requested presets
    local p preset_func
    for p in "${explicit_presets[@]+"${explicit_presets[@]}"}"; do
      preset_func="preset_${p}"
      if ! declare -f "$preset_func" >/dev/null 2>&1; then
        die "unknown preset: '$p'"
      fi
      "$preset_func" >> "$exclude_file"
      info "Applied exclude preset '$p' (requested via --exclude-preset)."
    done

    # Auto-detect presets from worktree contents (skip already-applied)
    local applied_str=""
    for p in "${explicit_presets[@]+"${explicit_presets[@]}"}"; do
      applied_str="$applied_str:$p"
    done

    local detected
    detected="$(detect_presets "$worktree")"
    if [[ -n "$detected" ]]; then
      while IFS= read -r p; do
        if [[ ":$applied_str:" == *":$p:"* ]]; then
          continue  # Already applied explicitly
        fi
        preset_func="preset_${p}"
        "$preset_func" >> "$exclude_file"
        info "Applied exclude preset '$p' (detected matching files)."
        info "  Undo: snap2git exclude $name --edit"
      done <<< "$detected"
    fi
  fi

  # Save to config
  config_set "$name" "worktree" "$worktree"
  config_set "$name" "branch" "main"
  config_set "$name" "commit_template" "Snapshot: %Y-%m-%d %H:%M:%S"

  # Create initial empty commit so the branch exists
  git --git-dir="$gitdir" --work-tree="$worktree" \
    commit --allow-empty -m "snap2git: initialized repo '$name'" --quiet

  info "Done! Take your first snapshot with: snap2git snapshot $name"
}

cmd_snapshot() {
  local dry_run=false stage_only=false message=""
  local name="" run_all=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all|-a)     run_all=true; shift ;;
      --dry-run|-n) dry_run=true; shift ;;
      --stage-only|-s) stage_only=true; shift ;;
      --message|-m) message="$2"; shift 2 ;;
      --help|-h) cmd_help; return 0 ;;
      -*) die "unknown option: $1" ;;
      *) name="$1"; shift ;;
    esac
  done

  if $run_all || [[ -z "$name" ]]; then
    run_for_all _snapshot_one "$dry_run" "$stage_only" "$message"
    return $?
  fi

  if is_group "$name"; then
    run_for_group "$name" _snapshot_one "$dry_run" "$stage_only" "$message"
    return $?
  fi

  _snapshot_one "$name" "$dry_run" "$stage_only" "$message"
}

# Internal: snapshot one repo. Args: name dry_run stage_only message
_snapshot_one() {
  local name="$1" dry_run="$2" stage_only="$3" message="$4"

  require_repo "$name"
  local gitdir worktree
  gitdir="$(repo_gitdir "$name")"
  worktree="$(repo_worktree "$name")"

  # Check for changes
  local changes_display change_count
  changes_display="$(snap_git "$name" status --porcelain)"
  if [[ -z "$changes_display" ]]; then
    info "No changes to snapshot in '$name'."
    return 0
  fi

  change_count="$(echo "$changes_display" | wc -l | tr -d ' ')"

  if $dry_run; then
    info "[dry run] $change_count file(s) changed in '$name':"
    echo "$changes_display"
    return 0
  fi

  # Warn about large files (parse path from column 4 onward for space safety)
  local large_files=""
  while IFS= read -r line; do
    local fpath="${line:3}"
    local full_path="$worktree/$fpath"
    if [[ -f "$full_path" ]]; then
      local size
      size=$(stat -f%z "$full_path" 2>/dev/null || stat -c%s "$full_path" 2>/dev/null || echo 0)
      if [[ "$size" -gt "$LARGE_FILE_WARN_BYTES" ]]; then
        local mb=$((size / 1024 / 1024))
        large_files+="  ${mb}MB  $fpath"$'\n'
      fi
    fi
  done <<< "$changes_display"
  if [[ -n "$large_files" ]]; then
    warn "Large files detected (>50MB):"
    printf '%s' "$large_files" >&2
  fi

  # Stage all changes, with retry for locked files
  local add_stderr
  add_stderr=$(mktemp)
  SNAP2GIT_TMPFILES+=("$add_stderr")
  local add_failed=false

  if ! snap_git "$name" add -A 2>"$add_stderr"; then
    add_failed=true
  fi

  # If add failed, check if it's file-level (locked/unreadable) or structural
  if $add_failed; then
    if grep -qi "permission denied\|unable to index\|could not read" "$add_stderr" 2>/dev/null; then
      warn "Some files could not be staged, retrying in 2s..."
      sleep 2
      local retry_stderr
      retry_stderr=$(mktemp)
      SNAP2GIT_TMPFILES+=("$retry_stderr")
      if ! snap_git "$name" add -A 2>"$retry_stderr"; then
        if grep -qi "permission denied\|unable to index\|could not read" "$retry_stderr" 2>/dev/null; then
          warn "Some files still locked/unreadable after retry:"
          cat "$retry_stderr" >&2
          # Continue with whatever was staged
        else
          # Structural git error on retry
          cat "$retry_stderr" >&2
          die "git add failed for '$name'"
        fi
      fi
    else
      # Structural git error (not a file-level issue)
      cat "$add_stderr" >&2
      die "git add failed for '$name'"
    fi
  fi

  # Check if anything was actually staged
  if snap_git "$name" diff --cached --quiet 2>/dev/null; then
    warn "No files could be staged for '$name' (all may be locked)."
    return 1
  fi

  info "Staged changes in '$name'."

  if $stage_only; then
    info "Changes staged but not committed (--stage-only)."
    return 0
  fi

  # Build commit message
  if [[ -z "$message" ]]; then
    local template
    template="$(config_get "$name" "commit_template" "Snapshot: %Y-%m-%d %H:%M:%S")"
    message="$(date +"$template")"
  fi

  snap_git "$name" commit -m "$message" --quiet

  # Auto-gc check (non-fatal if it fails)
  _maybe_auto_gc "$name" || true

  # If there were locked files, report partial success
  if $add_failed; then
    warn "Snapshot committed with some files skipped (locked/unreadable): $message"
    return 1
  fi

  info "Snapshot committed: $message"
}

cmd_status() {
  local name="" run_all=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all|-a) run_all=true; shift ;;
      --help|-h) cmd_help; return 0 ;;
      -*) die "unknown option: $1" ;;
      *) name="$1"; shift ;;
    esac
  done

  if $run_all || [[ -z "$name" ]]; then
    run_for_all _status_one
    return $?
  fi
  if is_group "$name"; then
    run_for_group "$name" _status_one
    return $?
  fi
  _status_one "$name"
}

_status_one() {
  local name="$1"
  require_repo "$name"

  local changes
  changes="$(snap_git "$name" status --porcelain)"
  if [[ -z "$changes" ]]; then
    info "No changes since last snapshot in '$name'."
  else
    local count
    count="$(echo "$changes" | wc -l | tr -d ' ')"
    info "$count file(s) changed in '$name':"
    echo "$changes"
  fi
}

cmd_log() {
  local name="${1:-}" count="${2:-20}"
  [[ -z "$name" ]] && die "usage: snap2git log <name> [count]"

  require_repo "$name"

  snap_git "$name" log \
    --oneline \
    --format="%C(dim)%h%C(reset) %C(green)%cd%C(reset) %s" \
    --date=format:"%Y-%m-%d %H:%M:%S" \
    -n "$count"
}

cmd_verify() {
  local name="" run_all=false
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all|-a) run_all=true; shift ;;
      --help|-h) cmd_help; return 0 ;;
      -*) die "unknown option: $1" ;;
      *) name="$1"; shift ;;
    esac
  done

  if $run_all || [[ -z "$name" ]]; then
    run_for_all _verify_one
    return $?
  fi
  if is_group "$name"; then
    run_for_group "$name" _verify_one
    return $?
  fi
  _verify_one "$name"
}

_verify_one() {
  local name="$1"
  require_repo "$name"

  local gitdir
  gitdir="$(repo_gitdir "$name")"
  info "Verifying integrity of '$name' ($(du -sh "$gitdir" | cut -f1))..."
  if snap_git "$name" fsck --no-progress 2>&1; then
    info "Integrity check passed."
  else
    die "Integrity check FAILED for '$name'. See errors above."
  fi
}

cmd_diff() {
  local name="" stat_mode=false name_only=false
  local ref1="" ref2=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --stat)      stat_mode=true; shift ;;
      --name-only) name_only=true; shift ;;
      --help|-h) cmd_help; return 0 ;;
      -*) die "unknown option: $1" ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        elif [[ -z "$ref1" ]]; then
          ref1="$1"
        else
          ref2="$1"
        fi
        shift
        ;;
    esac
  done

  [[ -z "$name" ]] && die "usage: snap2git diff <name> [ref1] [ref2] [--stat] [--name-only]"
  require_repo "$name"

  # Default: diff last two snapshots
  if [[ -z "$ref1" ]]; then
    # Check we have at least 2 commits
    local commit_count
    commit_count="$(snap_git "$name" rev-list --count HEAD 2>/dev/null || echo 0)"
    if [[ "$commit_count" -lt 2 ]]; then
      info "Only $commit_count snapshot(s) in '$name' - nothing to diff."
      return 0
    fi
    ref1="HEAD~1"
    ref2="HEAD"
  elif [[ -z "$ref2" ]]; then
    ref2="HEAD"
  fi

  local diff_opts=()
  if $stat_mode; then
    diff_opts+=(--stat)
  fi
  if $name_only; then
    diff_opts+=(--name-only)
  fi

  snap_git "$name" diff ${diff_opts[@]+"${diff_opts[@]}"} "$ref1" "$ref2"
}

cmd_checkout() {
  local name="" action="create" ref=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --list|-l)    action="list"; shift ;;
      --cleanup|-c) action="cleanup"; shift ;;
      --help|-h) cmd_help; return 0 ;;
      -*) die "unknown option: $1" ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        else
          ref="$1"
        fi
        shift
        ;;
    esac
  done

  [[ -z "$name" ]] && die "usage: snap2git checkout <name> <ref> | --list | --cleanup"
  require_repo "$name"

  case "$action" in
    list)    _checkout_list "$name" ;;
    cleanup) _checkout_cleanup "$name" ;;
    create)
      [[ -z "$ref" ]] && die "usage: snap2git checkout <name> <ref>"
      _checkout_create "$name" "$ref"
      ;;
  esac
}

_checkout_create() {
  local name="$1" ref="$2"
  local gitdir
  gitdir="$(repo_gitdir "$name")"

  # Resolve the ref to a short hash for the directory name
  local resolved
  resolved="$(snap_git "$name" rev-parse --short "$ref" 2>/dev/null)" \
    || die "unknown ref '$ref' in repo '$name'"

  local checkout_dir="$SNAP2GIT_HOME/${name}.checkout-${resolved}"

  if [[ -d "$checkout_dir" ]]; then
    info "Checkout already exists: $checkout_dir"
    return 0
  fi

  # Create the worktree
  git --git-dir="$gitdir" worktree add --detach "$checkout_dir" "$ref" --quiet 2>/dev/null \
    || die "failed to create checkout for '$ref' in repo '$name'"

  info "Checked out '$ref' ($resolved) to:"
  info "  $checkout_dir"
}

_checkout_list() {
  local name="$1"
  local gitdir
  gitdir="$(repo_gitdir "$name")"

  local worktrees
  worktrees="$(git --git-dir="$gitdir" worktree list 2>/dev/null)"

  # Filter to only our checkout directories
  local found=false
  while IFS= read -r line; do
    if [[ "$line" == *"${name}.checkout-"* ]]; then
      echo "$line"
      found=true
    fi
  done <<< "$worktrees"

  if ! $found; then
    info "No active checkouts for '$name'."
  fi
}

_checkout_cleanup() {
  local name="$1"
  local gitdir
  gitdir="$(repo_gitdir "$name")"
  local cleaned=0

  # Find and remove checkout directories
  local prefix="$SNAP2GIT_HOME/${name}.checkout-"
  for dir in "$prefix"*/; do
    [[ -d "$dir" ]] || continue
    git --git-dir="$gitdir" worktree remove "$dir" --force 2>/dev/null \
      || rm -rf "$dir"
    cleaned=$((cleaned + 1))
  done

  # Prune any stale worktree references
  git --git-dir="$gitdir" worktree prune 2>/dev/null

  if [[ "$cleaned" -eq 0 ]]; then
    info "No checkouts to clean up for '$name'."
  else
    info "Cleaned up $cleaned checkout(s) for '$name'."
  fi
}

cmd_gc() {
  local name="" run_all=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --all|-a) run_all=true; shift ;;
      --help|-h) cmd_help; return 0 ;;
      -*) die "unknown option: $1" ;;
      *) name="$1"; shift ;;
    esac
  done

  if $run_all || [[ -z "$name" ]]; then
    run_for_all _gc_one
    return $?
  fi

  if is_group "$name"; then
    run_for_group "$name" _gc_one
    return $?
  fi

  _gc_one "$name"
}

cmd_info() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "usage: snap2git info <name>"
  require_repo "$name"

  local gitdir worktree
  gitdir="$(repo_gitdir "$name")"
  worktree="$(repo_worktree "$name")"

  info "Repository: $name"
  info "  worktree: $worktree"
  info "  git-dir:  $gitdir"
  info "  size:     $(du -sh "$gitdir" 2>/dev/null | cut -f1)"

  # Snapshot count and date range
  local snap_count
  snap_count=$(git --git-dir="$gitdir" rev-list --count HEAD 2>/dev/null || echo 0)
  # Subtract 1 for the initial empty commit
  if [[ "$snap_count" -gt 0 ]]; then
    snap_count=$((snap_count - 1))
  fi
  info "  snapshots: $snap_count"

  if [[ "$snap_count" -gt 0 ]]; then
    local first_date last_date
    first_date=$(git --git-dir="$gitdir" log --reverse --format='%ci' | head -2 | tail -1)
    last_date=$(git --git-dir="$gitdir" log -1 --format='%ci')
    info "  first:    $first_date"
    info "  latest:   $last_date"
  fi

  # File stats from current HEAD
  local tree_data
  tree_data=$(git --git-dir="$gitdir" ls-tree -r -l HEAD 2>/dev/null || true)
  if [[ -z "$tree_data" ]]; then
    info "  files:    0 (empty)"
    return 0
  fi

  local file_count
  file_count=$(echo "$tree_data" | wc -l | tr -d ' ')
  info "  files:    $file_count"
  echo

  # Top 10 largest files
  info "Largest files:"
  echo "$tree_data" | awk '{
    size = $4
    path = ""
    for (i = 5; i <= NF; i++) path = (path ? path " " : "") $i
    printf "%12d %s\n", size, path
  }' | sort -rn | head -10 | awk '{
    size = $1
    path = ""
    for (i = 2; i <= NF; i++) path = (path ? path " " : "") $i
    if (size >= 1073741824) printf "  %6.1f GB  %s\n", size/1073741824, path
    else if (size >= 1048576) printf "  %6.1f MB  %s\n", size/1048576, path
    else if (size >= 1024) printf "  %6.1f KB  %s\n", size/1024, path
    else printf "  %6d B   %s\n", size, path
  }'
  echo

  # Breakdown by extension
  info "By extension:"
  echo "$tree_data" | awk '{
    size = $4
    path = ""
    for (i = 5; i <= NF; i++) path = (path ? path " " : "") $i
    # Extract extension
    n = split(path, parts, "/")
    fname = parts[n]
    if (match(fname, /\.[^.]+$/)) {
      ext = substr(fname, RSTART)
    } else {
      ext = "(none)"
    }
    count[ext]++
    total[ext] += size
  }
  END {
    for (ext in count) {
      printf "%12d %6d %s\n", total[ext], count[ext], ext
    }
  }' | sort -rn | head -20 | awk '{
    size = $1; cnt = $2; ext = $3
    if (size >= 1073741824) printf "  %6.1f GB  %5d files  %s\n", size/1073741824, cnt, ext
    else if (size >= 1048576) printf "  %6.1f MB  %5d files  %s\n", size/1048576, cnt, ext
    else if (size >= 1024) printf "  %6.1f KB  %5d files  %s\n", size/1024, cnt, ext
    else printf "  %6d B   %5d files  %s\n", size, cnt, ext
  }'
  echo

  # Flag potential excludes
  local suspects
  suspects=$(echo "$tree_data" | awk '{
    path = ""
    for (i = 5; i <= NF; i++) path = (path ? path " " : "") $i
    if (path ~ /\.(cache|log|tmp|bak)$/ ||
        path ~ /\/(\.cache|\.config|\.local|__pycache__|node_modules|\.Trash)\// ||
        path ~ /full-text-search\.db$/ ||
        path ~ /\.DS_Store$/ ||
        path ~ /thumbs\.db$/i)
      print "  " path
  }')
  if [[ -n "$suspects" ]]; then
    info "Potential excludes (app state / temp data):"
    echo "$suspects" | head -20
    local suspect_count
    suspect_count=$(echo "$suspects" | wc -l | tr -d ' ')
    if [[ "$suspect_count" -gt 20 ]]; then
      info "  ... and $((suspect_count - 20)) more"
    fi
  fi
}

_schedule_script_path() {
  # Resolve the absolute path to the snap2git script
  local script_path="${BASH_SOURCE[0]}"
  if [[ -L "$script_path" ]]; then
    # Follow symlinks
    script_path=$(cd "$(dirname "$script_path")" && pwd -P)/$(basename "$script_path")
  elif [[ "$script_path" != /* ]]; then
    script_path="$(cd "$(dirname "$script_path")" && pwd -P)/$(basename "$script_path")"
  fi
  echo "$script_path"
}

_schedule_plist_path() {
  local name="$1"
  echo "$HOME/Library/LaunchAgents/com.snap2git.${name}.plist"
}

_schedule_macos_add() {
  local name="$1" interval="$2"
  local plist_path script_path
  plist_path="$(_schedule_plist_path "$name")"
  script_path="$(_schedule_script_path)"
  local interval_seconds=$((interval * 60))

  mkdir -p "$HOME/Library/LaunchAgents"
  cat > "$plist_path" << PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.snap2git.${name}</string>
  <key>ProgramArguments</key>
  <array>
    <string>${script_path}</string>
    <string>snapshot</string>
    <string>${name}</string>
  </array>
  <key>StartInterval</key>
  <integer>${interval_seconds}</integer>
  <key>StandardOutPath</key>
  <string>${SNAP2GIT_HOME}/${name}.schedule.log</string>
  <key>StandardErrorPath</key>
  <string>${SNAP2GIT_HOME}/${name}.schedule.log</string>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
PLIST

  launchctl load "$plist_path" 2>/dev/null || true
  info "Scheduled '$name' every $interval minutes (macOS launchd)."
  info "  plist: $plist_path"
  info "  log:   $SNAP2GIT_HOME/${name}.schedule.log"
}

_schedule_macos_remove() {
  local name="$1"
  local plist_path
  plist_path="$(_schedule_plist_path "$name")"
  if [[ ! -f "$plist_path" ]]; then
    die "no schedule found for '$name'"
  fi
  launchctl unload "$plist_path" 2>/dev/null || true
  rm -f "$plist_path"
  info "Removed schedule for '$name'."
}

_schedule_macos_status() {
  local name="$1"
  local plist_path
  plist_path="$(_schedule_plist_path "$name")"
  if [[ -f "$plist_path" ]]; then
    local interval_seconds
    interval_seconds=$(grep -A1 '<key>StartInterval</key>' "$plist_path" | grep integer | sed 's/[^0-9]//g')
    local interval_minutes=$((interval_seconds / 60))
    info "Schedule active for '$name': every $interval_minutes minutes (macOS launchd)"
    info "  plist: $plist_path"
    if launchctl list "com.snap2git.${name}" >/dev/null 2>&1; then
      info "  status: loaded"
    else
      info "  status: not loaded (run 'launchctl load $plist_path' to start)"
    fi
  else
    info "No schedule configured for '$name'."
  fi
}

_schedule_cron_marker() {
  local name="$1"
  echo "# snap2git:${name}"
}

_schedule_cron_entry() {
  local name="$1" interval="$2"
  local script_path marker
  script_path="$(_schedule_script_path)"
  marker="$(_schedule_cron_marker "$name")"

  # Build cron schedule from minutes
  local cron_schedule
  if [[ "$interval" -le 59 ]]; then
    cron_schedule="*/$interval * * * *"
  elif [[ "$interval" -eq 60 ]]; then
    cron_schedule="0 * * * *"
  elif [[ $((interval % 60)) -eq 0 ]] && [[ $((interval / 60)) -le 23 ]]; then
    local hours=$((interval / 60))
    cron_schedule="0 */$hours * * *"
  elif [[ "$interval" -eq 1440 ]]; then
    cron_schedule="0 0 * * *"
  else
    # For awkward intervals, run hourly with a wrapper that checks elapsed time
    warn "Interval ${interval}m doesn't map cleanly to cron; rounding to nearest hour."
    local hours=$(( (interval + 30) / 60 ))
    if [[ "$hours" -lt 1 ]]; then
      hours=1
    fi
    if [[ "$hours" -le 23 ]]; then
      cron_schedule="0 */$hours * * *"
    else
      cron_schedule="0 0 * * *"
    fi
  fi

  echo "$cron_schedule $script_path snapshot $name $marker"
}

_schedule_linux_add() {
  local name="$1" interval="$2"
  local marker entry existing_crontab
  marker="$(_schedule_cron_marker "$name")"
  entry="$(_schedule_cron_entry "$name" "$interval")"

  # Get existing crontab (may be empty)
  existing_crontab=$(crontab -l 2>/dev/null || true)

  # Remove any existing snap2git entry for this repo
  local new_crontab
  new_crontab=$(echo "$existing_crontab" | grep -v "$marker" || true)

  # Append new entry
  if [[ -n "$new_crontab" ]]; then
    printf '%s\n%s\n' "$new_crontab" "$entry" | crontab -
  else
    echo "$entry" | crontab -
  fi

  info "Scheduled '$name' every $interval minutes (cron)."
  info "  entry: $entry"
}

_schedule_linux_remove() {
  local name="$1"
  local marker existing_crontab
  marker="$(_schedule_cron_marker "$name")"
  existing_crontab=$(crontab -l 2>/dev/null || true)

  if ! echo "$existing_crontab" | grep -q "$marker"; then
    die "no schedule found for '$name'"
  fi

  local new_crontab
  new_crontab=$(echo "$existing_crontab" | grep -v "$marker" || true)
  if [[ -n "$new_crontab" ]]; then
    echo "$new_crontab" | crontab -
  else
    crontab -r 2>/dev/null || true
  fi
  info "Removed schedule for '$name'."
}

_schedule_linux_status() {
  local name="$1"
  local marker existing_crontab
  marker="$(_schedule_cron_marker "$name")"
  existing_crontab=$(crontab -l 2>/dev/null || true)

  local entry
  entry=$(echo "$existing_crontab" | grep "$marker" || true)
  if [[ -n "$entry" ]]; then
    info "Schedule active for '$name' (cron)"
    info "  entry: $entry"
  else
    info "No schedule configured for '$name'."
  fi
}

cmd_schedule() {
  local name="" interval="" action="add"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --remove)  action="remove"; shift ;;
      --status)  action="status"; shift ;;
      --help|-h) cmd_help; return 0 ;;
      -*) die "unknown option: $1" ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        elif [[ -z "$interval" ]]; then
          interval="$1"
        fi
        shift
        ;;
    esac
  done

  [[ -z "$name" ]] && die "usage: snap2git schedule <name> <interval-minutes> [--remove|--status]"
  require_repo "$name"

  local platform
  platform=$(uname -s)

  case "$action" in
    status)
      case "$platform" in
        Darwin) _schedule_macos_status "$name" ;;
        *)      _schedule_linux_status "$name" ;;
      esac
      ;;
    remove)
      case "$platform" in
        Darwin) _schedule_macos_remove "$name" ;;
        *)      _schedule_linux_remove "$name" ;;
      esac
      ;;
    add)
      [[ -z "$interval" ]] && die "usage: snap2git schedule <name> <interval-minutes>"
      if ! [[ "$interval" =~ ^[0-9]+$ ]] || [[ "$interval" -lt 1 ]]; then
        die "interval must be a positive number of minutes"
      fi
      case "$platform" in
        Darwin) _schedule_macos_add "$name" "$interval" ;;
        *)      _schedule_linux_add "$name" "$interval" ;;
      esac
      ;;
  esac
}

cmd_list() {
  local repos
  repos="$(config_list_repos)"
  if [[ -z "$repos" ]]; then
    info "No repos configured. Run 'snap2git init <name> <path>' to get started."
    return 0
  fi

  info "Configured repos:"
  echo "$repos" | while read -r name; do
    local worktree gitdir
    worktree="$(expand_path "$(config_get "$name" "worktree" "(unknown)")")"
    gitdir="$(repo_gitdir "$name")"
    local status="ok"
    [[ ! -d "$gitdir" ]] && status="missing git-dir"
    [[ ! -d "$worktree" ]] && status="missing worktree"
    printf "  %-20s %s  [%s]\n" "$name" "$worktree" "$status"
  done
}

cmd_tag() {
  local name="" label="" action="tag"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --list|-l) action="list"; shift ;;
      --delete|-d)
        action="delete"
        [[ -n "${2:-}" && "${2:0:1}" != "-" ]] && { label="$2"; shift; }
        shift ;;
      --help|-h) cmd_help; return 0 ;;
      -*) die "unknown option: $1" ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        elif [[ -z "$label" ]]; then
          label="$1"
        fi
        shift
        ;;
    esac
  done

  [[ -z "$name" ]] && die "usage: snap2git tag <name> <label> [--list|--delete <label>]"
  require_repo "$name"

  case "$action" in
    list)
      snap_git "$name" tag -l
      ;;
    delete)
      [[ -z "$label" ]] && die "usage: snap2git tag <name> --delete <label>"
      snap_git "$name" tag -d "$label"
      info "Deleted tag '$label' from '$name'."
      ;;
    tag)
      [[ -z "$label" ]] && die "usage: snap2git tag <name> <label>"
      snap_git "$name" tag "$label"
      info "Tagged latest snapshot of '$name' as '$label'."
      ;;
  esac
}

cmd_search() {
  local name="" pattern="" mode="string" file_glob=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --regex|-r) mode="regex"; shift ;;
      --file|-f)
        [[ -z "${2:-}" ]] && die "--file requires a glob pattern"
        file_glob="$2"; shift 2 ;;
      --help|-h) cmd_help; return 0 ;;
      -*) die "unknown option: $1" ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        elif [[ -z "$pattern" ]]; then
          pattern="$1"
        fi
        shift
        ;;
    esac
  done

  [[ -z "$name" ]] && die "usage: snap2git search <name> <pattern> [--regex] [--file <glob>]"
  [[ -z "$pattern" ]] && die "usage: snap2git search <name> <pattern> [--regex] [--file <glob>]"
  require_repo "$name"

  local search_flag="-S"
  if [[ "$mode" == "regex" ]]; then
    search_flag="-G"
  fi

  local -a log_args=(
    log
    "$search_flag" "$pattern"
    --format="%C(dim)%h%C(reset) %C(green)%cd%C(reset) %s"
    --date=format:"%Y-%m-%d %H:%M:%S"
  )

  if [[ -n "$file_glob" ]]; then
    log_args+=("--" "$file_glob")
  fi

  snap_git "$name" "${log_args[@]}"
}

cmd_group() {
  local group_name="" action=""
  local repos_to_add=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --list|-l) action="list"; shift ;;
      add)
        action="add"
        shift
        while [[ $# -gt 0 && "${1:0:1}" != "-" ]]; do
          repos_to_add+=("$1"); shift
        done
        ;;
      remove)
        action="remove"
        shift
        while [[ $# -gt 0 && "${1:0:1}" != "-" ]]; do
          repos_to_add+=("$1"); shift
        done
        ;;
      --help|-h) cmd_help; return 0 ;;
      -*) die "unknown option: $1" ;;
      *)
        if [[ -z "$group_name" ]]; then
          group_name="$1"
        fi
        shift
        ;;
    esac
  done

  # List all groups
  if [[ "$action" == "list" || -z "$group_name" ]]; then
    local groups
    groups="$(config_list_groups)"
    if [[ -z "$groups" ]]; then
      info "No groups configured."
      return 0
    fi
    while IFS= read -r g; do
      local repos_csv
      repos_csv="$(config_get_group_repos "$g" | tr '\n' ',' | sed 's/,$//')"
      info "  $g: $repos_csv"
    done <<< "$groups"
    return 0
  fi

  # Validate group name doesn't collide with a repo name
  local repos_list
  repos_list="$(config_list_repos)"
  if [[ -n "$repos_list" ]] && echo "$repos_list" | grep -qx "$group_name"; then
    die "group name '$group_name' conflicts with an existing repo name"
  fi

  case "$action" in
    add)
      [[ ${#repos_to_add[@]} -eq 0 ]] && die "usage: snap2git group <name> add <repo> [repo...]"
      # Validate that each repo exists
      local r
      for r in "${repos_to_add[@]}"; do
        if ! config_get "$r" "worktree" "" | grep -q .; then
          die "repo '$r' does not exist"
        fi
      done
      # Get current repos, merge, deduplicate
      local current new_csv
      current="$(config_get_group_repos "$group_name")"
      local all_repos="$current"
      for r in "${repos_to_add[@]}"; do
        all_repos="$(printf '%s\n%s' "$all_repos" "$r")"
      done
      new_csv="$(echo "$all_repos" | grep -v '^$' | sort -u | tr '\n' ',' | sed 's/,$//')"
      config_set_group "$group_name" "$new_csv"
      info "Group '$group_name': $new_csv"
      ;;
    remove)
      [[ ${#repos_to_add[@]} -eq 0 ]] && die "usage: snap2git group <name> remove <repo>"
      local current_repos
      current_repos="$(config_get_group_repos "$group_name")"
      if [[ -z "$current_repos" ]]; then
        die "group '$group_name' does not exist"
      fi
      local r remaining=""
      for r in "${repos_to_add[@]}"; do
        if ! echo "$current_repos" | grep -qx "$r"; then
          die "repo '$r' is not in group '$group_name'"
        fi
      done
      # Filter out removed repos
      while IFS= read -r r; do
        local remove=false rr
        for rr in "${repos_to_add[@]}"; do
          if [[ "$r" == "$rr" ]]; then
            remove=true
            break
          fi
        done
        if ! $remove; then
          remaining="$(printf '%s\n%s' "$remaining" "$r")"
        fi
      done <<< "$current_repos"
      local new_csv
      new_csv="$(echo "$remaining" | grep -v '^$' | tr '\n' ',' | sed 's/,$//' || true)"
      if [[ -z "$new_csv" ]]; then
        config_remove_group "$group_name"
        info "Removed group '$group_name' (no repos remaining)."
      else
        config_set_group "$group_name" "$new_csv"
        info "Group '$group_name': $new_csv"
      fi
      ;;
    *)
      # Show group contents
      local repos_csv
      repos_csv="$(config_get_group_repos "$group_name" | tr '\n' ',' | sed 's/,$//')"
      if [[ -z "$repos_csv" ]]; then
        die "group '$group_name' does not exist"
      fi
      info "$group_name: $repos_csv"
      ;;
  esac
}

cmd_completion() {
  local shell="${1:-}"
  case "$shell" in
    bash) _completion_bash ;;
    zsh)  _completion_zsh ;;
    *)    die "usage: snap2git completion <bash|zsh>" ;;
  esac
}

_completion_bash() {
  cat << 'BASH_COMPLETION'
# snap2git bash completion
# Add to .bashrc: eval "$(snap2git completion bash)"

_snap2git() {
  local cur prev words cword
  _init_completion || return

  local commands="init snapshot status log diff verify checkout list config exclude gc info schedule tag search group completion help version"

  # Get repo and group names from config
  local config="${SNAP2GIT_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/snap2git/config}"
  local repo_names=""
  local group_names=""
  if [[ -f "$config" ]]; then
    repo_names="$(grep '^\[repo:' "$config" 2>/dev/null | sed 's/\[repo:\(.*\)\]/\1/' || true)"
    group_names="$(grep '^\[group:' "$config" 2>/dev/null | sed 's/\[group:\(.*\)\]/\1/' || true)"
  fi
  local all_names="$repo_names $group_names"

  # Complete command names at position 1
  if [[ $cword -eq 1 ]]; then
    COMPREPLY=( $(compgen -W "$commands $repo_names" -- "$cur") )
    return
  fi

  local cmd="${words[1]}"

  case "$cmd" in
    init)
      if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "--no-excludes --exclude-preset --help" -- "$cur") )
      elif [[ "$prev" == "--exclude-preset" ]]; then
        COMPREPLY=( $(compgen -W "calibre obsidian" -- "$cur") )
      elif [[ $cword -eq 3 ]]; then
        # Worktree path - complete directories
        COMPREPLY=( $(compgen -d -- "$cur") )
      fi
      ;;
    snapshot)
      if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "--all --dry-run --stage-only --message --help" -- "$cur") )
      else
        COMPREPLY=( $(compgen -W "$all_names" -- "$cur") )
      fi
      ;;
    status|verify)
      if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "--all --help" -- "$cur") )
      else
        COMPREPLY=( $(compgen -W "$all_names" -- "$cur") )
      fi
      ;;
    log|info)
      COMPREPLY=( $(compgen -W "$repo_names" -- "$cur") )
      ;;
    diff)
      if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "--stat --name-only --help" -- "$cur") )
      else
        COMPREPLY=( $(compgen -W "$repo_names" -- "$cur") )
      fi
      ;;
    checkout)
      if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "--list --cleanup --help" -- "$cur") )
      else
        COMPREPLY=( $(compgen -W "$repo_names" -- "$cur") )
      fi
      ;;
    config)
      COMPREPLY=( $(compgen -W "$repo_names" -- "$cur") )
      ;;
    exclude)
      if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "--list --edit --reset --preset --help" -- "$cur") )
      elif [[ "$prev" == "--preset" || "$prev" == "-p" ]]; then
        COMPREPLY=( $(compgen -W "calibre obsidian" -- "$cur") )
      else
        COMPREPLY=( $(compgen -W "$repo_names" -- "$cur") )
      fi
      ;;
    gc)
      if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "--all --help" -- "$cur") )
      else
        COMPREPLY=( $(compgen -W "$all_names" -- "$cur") )
      fi
      ;;
    schedule)
      if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "--status --remove --help" -- "$cur") )
      else
        COMPREPLY=( $(compgen -W "$repo_names" -- "$cur") )
      fi
      ;;
    tag)
      if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "--list --delete --help" -- "$cur") )
      else
        COMPREPLY=( $(compgen -W "$repo_names" -- "$cur") )
      fi
      ;;
    search)
      if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "--regex --file --help" -- "$cur") )
      else
        COMPREPLY=( $(compgen -W "$repo_names" -- "$cur") )
      fi
      ;;
    group)
      if [[ "$cur" == -* ]]; then
        COMPREPLY=( $(compgen -W "--list --help" -- "$cur") )
      elif [[ "$prev" == "add" ]]; then
        COMPREPLY=( $(compgen -W "$repo_names" -- "$cur") )
      elif [[ "$prev" == "remove" ]]; then
        COMPREPLY=( $(compgen -W "$repo_names" -- "$cur") )
      else
        COMPREPLY=( $(compgen -W "$group_names add remove" -- "$cur") )
      fi
      ;;
    completion)
      COMPREPLY=( $(compgen -W "bash zsh" -- "$cur") )
      ;;
  esac
}

complete -F _snap2git snap2git
BASH_COMPLETION
}

_completion_zsh() {
  cat << 'ZSH_COMPLETION'
# snap2git zsh completion
# Add to .zshrc: eval "$(snap2git completion zsh)"

_snap2git() {
  local config="${SNAP2GIT_CONFIG:-${XDG_CONFIG_HOME:-$HOME/.config}/snap2git/config}"
  local repo_names=()
  local group_names=()
  if [[ -f "$config" ]]; then
    repo_names=( ${(f)"$(grep '^\[repo:' "$config" 2>/dev/null | sed 's/\[repo:\(.*\)\]/\1/')"} )
    group_names=( ${(f)"$(grep '^\[group:' "$config" 2>/dev/null | sed 's/\[group:\(.*\)\]/\1/')"} )
  fi

  local -a commands=(
    'init:Initialize a new snapshot repo'
    'snapshot:Take a snapshot'
    'status:Show changes since last snapshot'
    'log:Show snapshot history'
    'diff:Compare two snapshots'
    'verify:Check repository integrity'
    'checkout:Check out a snapshot to a temp dir'
    'list:List configured repos'
    'config:Show or set config'
    'exclude:Manage exclude patterns'
    'gc:Run garbage collection'
    'info:Show repo statistics'
    'schedule:Schedule periodic snapshots'
    'tag:Tag a snapshot'
    'search:Find snapshots by content'
    'group:Manage repo groups'
    'completion:Generate shell completion'
    'help:Show help'
    'version:Show version'
  )

  _arguments -C \
    '1:command:->cmd' \
    '*::arg:->args'

  case "$state" in
    cmd)
      _describe 'command' commands
      compadd "${repo_names[@]}"
      ;;
    args)
      case "${words[1]}" in
        init)
          _arguments \
            '--no-excludes[Skip preset auto-detection]' \
            '--exclude-preset[Apply a named preset]:preset:(calibre obsidian)' \
            '1:name:' \
            '2:worktree:_directories'
          ;;
        snapshot)
          _arguments \
            '(-a --all)'{-a,--all}'[Operate on all repos]' \
            '(-n --dry-run)'{-n,--dry-run}'[Show what would happen]' \
            '(-s --stage-only)'{-s,--stage-only}'[Stage only]' \
            '(-m --message)'{-m,--message}'[Custom message]:message:' \
            '1:name:compadd '"${repo_names[*]} ${group_names[*]}"
          ;;
        status|verify|gc)
          _arguments \
            '(-a --all)'{-a,--all}'[Operate on all repos]' \
            '1:name:compadd '"${repo_names[*]} ${group_names[*]}"
          ;;
        log|info|config)
          _arguments '1:name:compadd '"${repo_names[*]}"
          ;;
        diff)
          _arguments \
            '--stat[Show summary]' \
            '--name-only[Show only file paths]' \
            '1:name:compadd '"${repo_names[*]}"
          ;;
        checkout)
          _arguments \
            '(-l --list)'{-l,--list}'[Show active checkouts]' \
            '--cleanup[Remove temp checkouts]' \
            '1:name:compadd '"${repo_names[*]}"
          ;;
        exclude)
          _arguments \
            '(-l --list)'{-l,--list}'[Show excludes]' \
            '(-e --edit)'{-e,--edit}'[Edit excludes]' \
            '--reset[Reset to defaults]' \
            '(-p --preset)'{-p,--preset}'[Apply preset]:preset:(calibre obsidian)' \
            '1:name:compadd '"${repo_names[*]}"
          ;;
        schedule)
          _arguments \
            '--status[Show schedule status]' \
            '--remove[Remove schedule]' \
            '1:name:compadd '"${repo_names[*]}"
          ;;
        tag)
          _arguments \
            '(-l --list)'{-l,--list}'[List tags]' \
            '(-d --delete)'{-d,--delete}'[Delete a tag]' \
            '1:name:compadd '"${repo_names[*]}"
          ;;
        search)
          _arguments \
            '(-r --regex)'{-r,--regex}'[Use regex matching]' \
            '(-f --file)'{-f,--file}'[Restrict to files]:glob:' \
            '1:name:compadd '"${repo_names[*]}"
          ;;
        group)
          _arguments \
            '(-l --list)'{-l,--list}'[List groups]' \
            '1:group:compadd '"${group_names[*]}" \
            '2:action:(add remove)'
          ;;
        completion)
          _arguments '1:shell:(bash zsh)'
          ;;
      esac
      ;;
  esac
}

compdef _snap2git snap2git
ZSH_COMPLETION
}

cmd_help() {
  cat << 'HELP'
snap2git - Git-powered snapshots for file collections

Usage:
  snap2git [--force] <command> [options]

Commands:
  init <name> <path>     Initialize a new snapshot repo
  snapshot <name>        Take a snapshot (default command)
  status <name>          Show changes since last snapshot
  log <name> [count]     Show snapshot history
  diff <name> [r1] [r2]  Compare two snapshots
  verify <name>          Check repository integrity
  checkout <name> <ref>  Check out a snapshot to a temp dir
  checkout <name> --list Show active checkouts
  checkout <name> --cleanup  Remove temp checkouts
  list                   List configured repos
  config <name>          Show config for a repo
  config <name> <k> <v>  Set a config value
  exclude <name> <pat>   Add an exclude pattern
  exclude <name> --list  Show current excludes
  exclude <name> --edit  Open excludes in \$EDITOR
  exclude <name> --reset Reset to default excludes
  exclude <name> -p TYPE Apply a preset (e.g. calibre)
  gc <name>              Run garbage collection
  gc --all               GC all repos
  info <name>            Show repo statistics
  schedule <name> <min>  Schedule periodic snapshots
  schedule <name> --status  Show schedule status
  schedule <name> --remove  Remove schedule
  tag <name> <label>     Tag the latest snapshot
  tag <name> --list      List tags
  tag <name> --delete L  Delete a tag
  search <name> <pat>    Find snapshots by content changes
  group <name> add REPO  Add repos to a group
  group <name> remove R  Remove repo from a group
  group --list           List all groups
  completion <shell>     Generate shell completion (bash or zsh)
  help                   Show this help
  version                Show version

Global options:
  --force                Skip config validation

Init options:
  --no-excludes          Skip preset auto-detection
  --exclude-preset TYPE  Apply a specific exclude preset

Snapshot options:
  --all, -a              Operate on all repos
  --dry-run, -n          Show what would happen without doing it
  --stage-only, -s       Stage changes but don't commit
  --message, -m MSG      Use a custom commit message

Status/verify/gc options:
  --all, -a              Operate on all repos

Diff options:
  --stat                 Show summary of changes
  --name-only            Show only changed file paths

Search options:
  --regex, -r            Use regex matching (git log -G)
  --file, -f GLOB        Restrict to files matching glob

Auto-gc:
  Runs after every 50 snapshots by default. Configure per-repo:
    snap2git config <name> auto_gc_interval 100   (every 100 snapshots)
    snap2git config <name> auto_gc_interval 0     (disable)

Note: When name is omitted, snapshot/status/verify/gc operate on all repos.
      Group names work in place of repo names for these commands.

Config file:
  Location: ~/.config/snap2git/config (or $SNAP2GIT_CONFIG)
  Format: INI-style with [repo:NAME] sections.
  Lines starting with # or ; are comments.

Examples:
  snap2git init my-notes ~/Library/Mobile\ Documents/Notes
  snap2git snapshot my-notes
  snap2git snapshot my-notes --dry-run
  snap2git status my-notes
  snap2git log my-notes
  snap2git gc my-notes
  snap2git info my-notes
  snap2git schedule my-notes 60
  snap2git config my-notes
  snap2git config my-notes commit_template "Backup: %Y-%m-%d"

Environment:
  SNAP2GIT_HOME          Base dir for git repos (default: ~/.snap2git)
  SNAP2GIT_CONFIG        Config file path (default: ~/.config/snap2git/config)
HELP
}

cmd_config() {
  local name="${1:-}"
  [[ -z "$name" ]] && die "usage: snap2git config <name> [<key> <value>]"

  local key="${2:-}" value="${3:-}"

  if [[ -z "$key" ]]; then
    # Show config for this repo
    local output
    output="$(config_show "$name")"
    if [[ -z "$output" ]]; then
      die "no config found for repo '$name'"
    fi
    echo "$output"
  else
    [[ -z "$value" ]] && die "usage: snap2git config <name> <key> <value>"
    config_set "$name" "$key" "$value"
    info "Set $key = $value for repo '$name'"
  fi
}

# --- Main ------------------------------------------------------------------

main() {
  local force=false

  # Parse global options before the command
  while [[ "${1:-}" == --* ]]; do
    case "$1" in
      --force) force=true; shift ;;
      --help|-h) cmd_help; return ;;
      --version|-v) echo "snap2git $SNAP2GIT_VERSION"; return ;;
      *) break ;;
    esac
  done

  local cmd="${1:-help}"
  shift 2>/dev/null || true

  # Validate config (skip for init, help, version - they don't need valid config)
  case "$cmd" in
    init|help|version|completion) ;;
    *)
      if ! config_validate; then
        if $force; then
          warn "config validation failed, continuing with --force"
        else
          die "config validation failed (use --force to override)"
        fi
      fi
      ;;
  esac

  case "$cmd" in
    init)       cmd_init "$@" ;;
    snapshot)   cmd_snapshot "$@" ;;
    status)     cmd_status "$@" ;;
    log)        cmd_log "$@" ;;
    verify)     cmd_verify "$@" ;;
    diff)       cmd_diff "$@" ;;
    checkout)   cmd_checkout "$@" ;;
    gc)         cmd_gc "$@" ;;
    info)       cmd_info "$@" ;;
    schedule)   cmd_schedule "$@" ;;
    list)       cmd_list "$@" ;;
    config)     cmd_config "$@" ;;
    exclude)    cmd_exclude "$@" ;;
    tag)        cmd_tag "$@" ;;
    search)     cmd_search "$@" ;;
    group)      cmd_group "$@" ;;
    completion) cmd_completion "$@" ;;
    help|-h)    cmd_help ;;
    version|-v) echo "snap2git $SNAP2GIT_VERSION" ;;
    *)
      # If it looks like a known repo name, treat as snapshot shorthand
      if [[ -d "$(repo_gitdir "$cmd")" ]]; then
        cmd_snapshot "$cmd" "$@"
      else
        die "unknown command: '$cmd' (see 'snap2git help')"
      fi
      ;;
  esac
}

main "$@"
